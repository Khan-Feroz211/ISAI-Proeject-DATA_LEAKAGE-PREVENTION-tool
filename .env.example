# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_ENV=production
SECRET_KEY=change-me-to-a-long-random-string

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default – good for dev/small deployments)
DATABASE_URL=sqlite:///dlp.db
# PostgreSQL (recommended for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/dlp_db

# ── Email Alerts ──────────────────────────────────────────────────────────────
DLP_SMTP_SERVER=smtp.example.com
DLP_SMTP_PORT=587
DLP_SMTP_SENDER=dlp@example.com
DLP_SMTP_RECIPIENT=admin@example.com
DLP_SMTP_PASSWORD=

# ── Admin account (created on first run) ─────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-on-first-run

# ── MLOps ─────────────────────────────────────────────────────────────────────
MODEL_REGISTRY_PATH=./mlops/registry
MLOPS_METRICS_PATH=./mlops/metrics

# ── Scanner defaults ──────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
SCAN_CONFIDENCE_THRESHOLD=0.75
